# ===========================
# 项目根目录 .gitignore
# ===========================

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ---------- IDE ----------
.idea/
*.iws
*.iml
*.ipr
.vscode/
*.code-workspace
.project
.classpath
.settings/
chat/

# ---------- 后端 (Java / Maven) ----------
backend/matching-system/target/
backend/matching-system/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# ---------- 前端 (Node / Vite) ----------
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
*.local

# ---------- 日志 ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Docker ----------
docker-data/

# ---------- 环境变量 ----------
.env
.env.local
.env.*.local
/.VSCodeCounter
